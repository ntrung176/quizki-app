rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == 'ntrungforwork@gmail.com' ||
              request.auth.token.email == 'lynguyennhattrung1706@gmail.com');
    }
    
    function isModerator(appId) {
      return isAuthenticated() &&
             (
               (appId != null && exists(/databases/$(database)/documents/artifacts/$(appId)/settings/adminConfig) && request.auth.uid in get(/databases/$(database)/documents/artifacts/$(appId)/settings/adminConfig).data.moderators) ||
               (exists(/databases/$(database)/documents/artifacts/1:28989364918:web:a2a99ad33fc0c23fca6417/settings/adminConfig) && request.auth.uid in get(/databases/$(database)/documents/artifacts/1:28989364918:web:a2a99ad33fc0c23fca6417/settings/adminConfig).data.moderators)
             );
    }
    
    function hasAdminPrivileges(appId) {
      return isAdmin() || isModerator(appId);
    }
    
    function isReasonableSize() {
      // Tăng giới hạn trường dữ liệu lên 80 để tránh lỗi ghi thẻ từ vựng lớn (45+ trường)
      return request.resource.data.keys().size() <= 80;
    }
    
    // ============================================
    // 1. USER DATA (Dữ liệu riêng tư của người dùng)
    // ============================================
    
    match /artifacts/{appId}/users/{userId}/settings/{docId} {
      allow read: if isOwner(userId) || hasAdminPrivileges(appId);
      allow create: if (isOwner(userId) && isReasonableSize()) || hasAdminPrivileges(appId);
      // LƯU Ý BẢO MẬT: Đã chặn quyền update profile/credits từ client
      // Luồng cộng tiền hiện tại được xử lý hoàn toàn qua Cloudflare Workers Webhook (Admin SDK) bảo mật.
      allow update: if hasAdminPrivileges(appId) || 
                    (
                      isOwner(userId) && 
                      (
                        // Trường hợp 1: Cập nhật thông tin thông thường (không chạm đến credits và premium)
                        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['aiCreditsRemaining', 'isPremiumUnlocked', 'premiumExpiresAt', 'unlockedSpecializedPackages']) ||
                        
                        // Trường hợp 2: Khởi tạo aiCreditsRemaining từ null/undefined thành 100
                        (
                          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['aiCreditsRemaining']) &&
                          (!('aiCreditsRemaining' in resource.data) || resource.data.aiCreditsRemaining == null) &&
                          request.resource.data.aiCreditsRemaining == 100
                        ) ||
                        
                        // Trường hợp 3: Người được giới thiệu tự động kích hoạt 15 ngày Premium dùng thử khi nhập mã giới thiệu
                        (
                          // Phải có trường referredBy lần đầu tiên
                          request.resource.data.referredBy != null &&
                          (!('referredBy' in resource.data) || resource.data.referredBy == null) &&
                          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['referredBy', 'isPremiumUnlocked', 'premiumExpiresAt', 'unlockedSpecializedPackages']) &&
                          // Giới hạn số ngày dùng thử tối đa là 15 ngày (15 * 24 * 60 * 60 * 1000 = 1296000000 ms) + 1 phút đệm
                          (
                            (!('premiumExpiresAt' in resource.data) || resource.data.premiumExpiresAt == null || resource.data.premiumExpiresAt < request.time.toMillis()) ? 
                            request.resource.data.premiumExpiresAt <= request.time.toMillis() + 1296060000 : 
                            request.resource.data.premiumExpiresAt <= resource.data.premiumExpiresAt + 1296060000
                          )
                        )
                      )
                    ) ||
                    (
                      // Trường hợp 4: Cho phép người được giới thiệu cộng 3 ngày Premium cho người giới thiệu (chủ tài khoản profile này)
                      isAuthenticated() &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isPremiumUnlocked', 'premiumExpiresAt', 'unlockedSpecializedPackages']) &&
                      // Giới hạn số ngày cộng thêm tối đa là 3 ngày (3 * 24 * 60 * 60 * 1000 = 259200000 ms) + 1 phút đệm
                      (
                        (!('premiumExpiresAt' in resource.data) || resource.data.premiumExpiresAt == null || resource.data.premiumExpiresAt < request.time.toMillis()) ? 
                        request.resource.data.premiumExpiresAt <= request.time.toMillis() + 259260000 : 
                        request.resource.data.premiumExpiresAt <= resource.data.premiumExpiresAt + 259260000
                      )
                    );
      allow delete: if isOwner(userId) || hasAdminPrivileges(appId);
    }
    
    match /artifacts/{appId}/users/{userId}/vocabulary/{vocabId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isReasonableSize();
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId) || hasAdminPrivileges(appId);
    }
    
    match /artifacts/{appId}/users/{userId}/dailyActivity/{logId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId) || hasAdminPrivileges(appId);
    }
    
    match /artifacts/{appId}/users/{userId}/kanjiSRS/{kanjiId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId) || hasAdminPrivileges(appId);
    }
    
    match /artifacts/{appId}/users/{userId}/kanjiProgress/{progressId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId) || hasAdminPrivileges(appId);
    }

    match /artifacts/{appId}/users/{userId}/studySets/{studySetId} {
      allow read: if isOwner(userId) || hasAdminPrivileges(appId);
      allow create: if isOwner(userId) && isReasonableSize();
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId) || hasAdminPrivileges(appId);
    }
    
    match /artifacts/{appId}/users/{userId} {
      allow read: if isOwner(userId) || hasAdminPrivileges(appId);
      allow write: if isOwner(userId) || hasAdminPrivileges(appId);
    }
    
    // ============================================
    // 2. SHARED DATA & UPDATES (Dữ liệu chia sẻ)
    // ============================================
    
    match /artifacts/{appId}/sharedVocab/{vocabId} {
      allow read: if true; // Cho phép xem công khai
      allow create: if isAuthenticated() && isReasonableSize() &&
                    (
                      (request.resource.data.word is string && request.resource.data.word.size() > 0) ||
                      (request.resource.data.front is string && request.resource.data.front.size() > 0)
                    ) &&
                    (
                      (request.resource.data.meaning is string && request.resource.data.meaning.size() > 0) ||
                      (request.resource.data.back is string && request.resource.data.back.size() > 0)
                    );
      allow update: if isAuthenticated() &&
                    (
                      (request.resource.data.meaning is string && request.resource.data.meaning.size() > 0) ||
                      (request.resource.data.back is string && request.resource.data.back.size() > 0)
                    );
      allow delete: if hasAdminPrivileges(appId);
    }
    
    match /artifacts/{appId}/bookVocabUpdates/{updateId} {
      allow read: if true;
      allow write: if hasAdminPrivileges(appId);
    }
    
    match /sharedVocabulary/{vocabId} {
      allow read: if true;
      allow create: if isAuthenticated() && isReasonableSize() &&
                    (
                      (request.resource.data.word is string && request.resource.data.word.size() > 0) ||
                      (request.resource.data.front is string && request.resource.data.front.size() > 0)
                    ) &&
                    (
                      (request.resource.data.meaning is string && request.resource.data.meaning.size() > 0) ||
                      (request.resource.data.back is string && request.resource.data.back.size() > 0)
                    );
      allow update: if isAuthenticated() &&
                    (
                      (request.resource.data.meaning is string && request.resource.data.meaning.size() > 0) ||
                      (request.resource.data.back is string && request.resource.data.back.size() > 0)
                    );
      allow delete: if hasAdminPrivileges(appId);
    }

    match /artifacts/{appId}/referrals/{referredId} {
      allow read: if isAuthenticated() && (request.auth.uid == referredId || resource.data.referrerId == request.auth.uid || hasAdminPrivileges(appId));
      allow create: if isAuthenticated() && request.auth.uid == referredId &&
                    request.resource.data.referredId == referredId &&
                    request.resource.data.status == 'pending' &&
                    request.resource.data.rewarded == false;
      allow update: if hasAdminPrivileges(appId);
      allow delete: if hasAdminPrivileges(appId);
    }
    
    match /artifacts/{appId}/public/data/userStats/{userId} {
      allow read: if true;
      allow create: if isOwner(userId) || hasAdminPrivileges(appId);
      allow update: if isOwner(userId) || hasAdminPrivileges(appId) || (
                      // Cho phép cập nhật thông tin premium của người khác khi cộng thưởng giới thiệu
                      isAuthenticated() &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isPremiumUnlocked', 'isPremium', 'premiumExpiresAt', 'unlockedSpecializedPackages']) &&
                      (
                        (!('premiumExpiresAt' in resource.data) || resource.data.premiumExpiresAt == null || resource.data.premiumExpiresAt < request.time.toMillis()) ? 
                        request.resource.data.premiumExpiresAt <= request.time.toMillis() + 259260000 : 
                        request.resource.data.premiumExpiresAt <= resource.data.premiumExpiresAt + 259260000
                      )
                    );
      allow delete: if isOwner(userId) || hasAdminPrivileges(appId);
    }
    
    // ============================================
    // 3. ADMIN SETTINGS (Cấu hình hệ thống)
    // ============================================
    
    match /artifacts/{appId}/settings/{docId} {
      allow read: if true; // Cho phép đọc cấu hình hệ thống công khai
      allow write: if isAdmin();
    }
    
    // ============================================
    // 4. KANJI DATA (Dữ liệu Kanji)
    // ============================================
    
    match /kanji/{kanjiId} {
      allow read: if true;
      allow write: if hasAdminPrivileges(appId); 
    }
    
    match /kanjiVocab/{vocabId} {
      allow read: if true;
      allow write: if hasAdminPrivileges(appId);
    }
    
    match /vocabCategories/{catId} {
      allow read: if true;
      allow write: if hasAdminPrivileges(appId);
    }
    
    match /kanjiLinkedBooks/{linkId} {
      allow read: if true;
      allow write: if hasAdminPrivileges(appId);
    }
    
    match /kanjiImportedBooks/{document} {
      allow read: if true;
      allow write: if hasAdminPrivileges(appId);
    }
    
    // ============================================
    // 5. BOOK DATA & LESSONS (Sách & Bài học)
    // ============================================
    
    match /bookGroups/{groupId} {
      allow read: if true;
      allow write: if hasAdminPrivileges(appId);
      
      match /books/{bookId} {
        allow read: if true;
        allow write: if hasAdminPrivileges(appId);
        
        match /chapters/{chapterId} {
          allow read: if true;
          allow write: if hasAdminPrivileges(appId);
          
          match /lessons/{lessonId} {
            allow read: if true;
            allow write: if hasAdminPrivileges(appId);
            
            match /vocabulary/{vocabId} {
              allow read: if true;
              allow write: if hasAdminPrivileges(appId);
            }
            
            match /vocabAudio/{audioId} {
              allow read: if true;
              allow write: if hasAdminPrivileges(appId);
            }
          }
        }
      }
    }
    
    // Cho phép truy cập bài học theo collection group
    match /{path=**}/lessons/{lessonId} {
      allow read: if true;
    }
    
    // ============================================
    // 6. JLPT TESTS (Đề thi thử)
    // ============================================
    
    match /artifacts/{appId}/jlptTests/{testId} {
      allow read: if true;
      allow write: if hasAdminPrivileges(appId);
      
      match /{subcollection}/{docId} {
        allow read: if true;
        allow write: if hasAdminPrivileges(appId);
      }
    }
    
    // ============================================
    // 7. FEEDBACK (Góp ý)
    // ============================================
    
    match /feedback/{feedbackId} {
      allow create: if isAuthenticated();
      allow read: if hasAdminPrivileges(appId);
      allow update, delete: if hasAdminPrivileges(appId);
    }
    
    // ============================================
    // 8. VOUCHERS (Mã giảm giá)
    // ============================================
    
    match /artifacts/{appId}/vouchers/{voucherId} {
      allow read: if isAuthenticated();
      allow create: if hasAdminPrivileges(appId);
      allow update: if hasAdminPrivileges(appId) || (
        isAuthenticated() && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['discountValue', 'discountType', 'maxUses', 'expiresAt', 'code', 'active', 'createdAt', 'createdBy'])
      );
      allow delete: if hasAdminPrivileges(appId);
    }
    
    // ============================================
    // 9. CREDIT REQUESTS (Yêu cầu nạp credit)
    // ============================================
    
    match /artifacts/{appId}/creditRequests/{requestId} {
      allow create: if isAuthenticated() && (
        hasAdminPrivileges(appId) ||
        (
          request.resource.data.userId == request.auth.uid &&
          (
            request.resource.data.status == 'pending' ||
            (
              request.resource.data.status == 'approved' &&
              request.resource.data.autoApproved == true &&
              request.resource.data.transactionId != null &&
              exists(/databases/$(database)/documents/artifacts/$(appId)/processedTransactions/$(request.resource.data.transactionId))
            )
          )
        )
      );
      allow read: if hasAdminPrivileges(appId) || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow update: if hasAdminPrivileges(appId);
      allow delete: if hasAdminPrivileges(appId);
    }
    
    // ============================================
    // 10. PROCESSED TRANSACTIONS (Giao dịch đã xử lý)
    // ============================================
    
    match /artifacts/{appId}/processedTransactions/{txId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || hasAdminPrivileges(appId));
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }
    
    // ============================================
    // 11. EXPENSES (Quản lý thu chi)
    // ============================================
    
    match /artifacts/{appId}/expenses/{expenseId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================
    // 12. FORUM & COMMENTS (Mạng xã hội học tập)
    // ============================================
    
    match /artifacts/{appId}/forum/{postId} {
      allow read: if true;
      allow create: if isAuthenticated() && isOwner(request.resource.data.authorId);
      allow update: if hasAdminPrivileges(appId) || (
        isOwner(resource.data.authorId) && 
        (!request.resource.data.keys().hasAny(['authorId']) || request.resource.data.authorId == resource.data.authorId)
      );
      allow delete: if hasAdminPrivileges(appId) || isOwner(resource.data.authorId);
      
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated() && isOwner(request.resource.data.authorId);
        allow update: if hasAdminPrivileges(appId) || (
          isOwner(resource.data.authorId) && 
          (!request.resource.data.keys().hasAny(['authorId']) || request.resource.data.authorId == resource.data.authorId)
        );
        allow delete: if hasAdminPrivileges(appId) || isOwner(resource.data.authorId);
      }
    }
    
    // ============================================
    // 13. USER PROFILES (Hồ sơ người dùng)
    // ============================================
    
    match /artifacts/{appId}/userProfiles/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId) || hasAdminPrivileges(appId);
    }
    
    // ============================================
    // 14. FOLLOWS (Theo dõi)
    // ============================================
    
    match /artifacts/{appId}/follows/{docId} {
      allow read: if true;
      allow create: if isAuthenticated() 
        && request.resource.data.followerId == request.auth.uid;
      allow delete: if isAuthenticated() 
        && resource.data.followerId == request.auth.uid;
    }

    // ============================================
    // 15. GRAMMAR DATA (Ngữ pháp)
    // ============================================
    
    match /artifacts/{appId}/grammarTextbooks/{textbookId} {
      allow read: if true;
      allow write: if hasAdminPrivileges(appId);
      
      match /lessons/{lessonId} {
        allow read: if true;
        allow write: if hasAdminPrivileges(appId);
        
        match /points/{pointId} {
          allow read: if true;
          allow write: if hasAdminPrivileges(appId);
        }
      }
    }

    // ============================================
    // 16. GLOBAL NOTIFICATIONS (Thông báo hệ thống)
    // ============================================
    
    match /artifacts/{appId}/globalNotifications/{notificationId} {
      allow read: if true;
      allow write: if hasAdminPrivileges(appId);
    }

    // ============================================
    // 17. CATCH-ALL DENY (Luôn để cuối cùng)
    // ============================================
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
